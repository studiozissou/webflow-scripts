      "position": [220, 360],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Validate the token: must exist, not be expired, not be consumed.\nconst token = $('Webhook').first().json.query.token;\nconst rows = items.map(i => i.json).filter(r => r && r.token);\nconst row = rows.find(r => r.token === token) || null;\n\nlet valid = false;\nlet reason = 'not_found';\n\nif (row) {\n  const consumed = row.consumed === true || row.consumed === 'true';\n  const expired = row.expiresAt ? new Date(row.expiresAt).getTime() < Date.now() : false;\n  if (consumed) reason = 'already_consumed';\n  else if (expired) reason = 'expired';\n  else { valid = true; reason = 'ok'; }\n}\n\nreturn [{ json: { ...(row || {}), token, valid, reason, locale: (row && row.locale) || 'nl' } }];"
      },
      "id": "b2000000-0000-4000-8000-000000000003",
      "name": "Validate Token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 360]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 2 },
          "conditions": [
            {
              "id": "d0000000-0000-4000-8000-000000000001",
              "leftValue": "={{ $json.valid }}",
              "rightValue": "",
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
