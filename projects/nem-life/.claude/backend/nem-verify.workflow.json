    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-opus-4-8', max_tokens: 8000, system: 'REPLACE_WITH_ALEX_SYSTEM_PROMPT_FROM_NOTION', messages: [ { role: 'user', content: 'Locale: ' + $json.locale + '. Write the full report in ' + ($json.locale === 'en' ? 'English' : 'Dutch') + '.\\n\\nFirst name: ' + $json.firstName + '\\nGender: ' + $json.gender + '\\nAge category: ' + $json.ageCategory + '\\nRelationship status: ' + $json.relationshipStatus + '\\n\\nMechanism scores (JSON): ' + $json.scoresJson + '\\nPrimary mechanism: ' + $json.primaryMechanism + '\\nSecondary mechanism: ' + ($json.secondaryMechanism || 'none') + '\\nTotal score: ' + $json.totalScore } ] }) }}",
        "options": {}
      },
      "id": "b2000000-0000-4000-8000-000000000007",
      "name": "Generate Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 360],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "// Pull the report text out of the Anthropic response and wrap it in HTML.\nconst res = $json;\nconst textBlock = (res.content || []).find(b => b.type === 'text');\nconst raw = textBlock ? textBlock.text : '';\nconst reportHtml = raw.split('\\n\\n').map(p => '<p>' + p.replace(/\\n/g, '<br>') + '</p>').join('');\nconst p = $('Validate Token').first().json;\nconst heading = p.locale === 'en' ? 'Your NEM Test report' : 'Jouw NEM Test rapport';\nconst greeting = p.locale === 'en' ? 'Dear' : 'Beste';\nconst html = '<!doctype html><html><head><meta charset=\"utf-8\"><style>body{font-family:Georgia,\"Times New Roman\",serif;color:#292828;max-width:640px;margin:0 auto;padding:48px 40px;line-height:1.6;font-size:16px}h1{font-family:Montserrat,Arial,sans-serif;font-size:24px;color:#292828}p{margin:0 0 16px}</style></head><body><h1>' + heading + '</h1><p>' + greeting + ' ' + (p.firstName || '') + ',</p>' + reportHtml + '</body></html>';\nreturn [{ json: { html, reportText: raw, ...p } }];"
      },
      "id": "b2000000-0000-4000-8000-000000000008",
      "name": "Build HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 360]
    },
