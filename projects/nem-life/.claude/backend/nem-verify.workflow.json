            { "name": "Content-Type", "value": "application/json" },
            { "name": "X-Requested-With", "value": "XMLHttpRequest" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ from: { email: 'hallo@nemmatters.com', name: 'NEM Life' }, to: [ { email: $('Validate Token').first().json.email, name: $('Validate Token').first().json.firstName } ], subject: $('Validate Token').first().json.locale === 'en' ? 'Your NEM Test report' : 'Jouw NEM Test rapport', text: $('Validate Token').first().json.locale === 'en' ? 'Your personal report is attached as a PDF.' : 'Je persoonlijke rapport zit als PDF in de bijlage.', attachments: [ { content: $json.pdfBase64, filename: 'NEM-rapport.pdf', disposition: 'attachment' } ] }) }}",
        "options": {}
      },
