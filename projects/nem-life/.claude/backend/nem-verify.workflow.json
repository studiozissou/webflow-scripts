        "method": "POST",
        "url": "https://api.pdfshift.io/v3/convert/pdf",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ source: $json.html }) }}",
        "options": { "response": { "response": { "responseFormat": "file", "outputPropertyName": "data" } } }
      },
      "id": "b2000000-0000-4000-8000-000000000009",
      "name": "Render PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 360]
    },
    {
      "parameters": {
        "jsCode": "// Base64-encode the PDFShift binary so MailerSend can attach it.\n// (n8n Cloud stores binary on the filesystem, so $binary.data.data is a ref,\n// not base64 — read the buffer explicitly and encode it here.)\nconst out = [];\nfor (let i = 0; i < items.length; i++) {\n  const buf = await this.helpers.getBinaryDataBuffer(i, 'data');\n  out.push({ json: { ...items[i].json, pdfBase64: buf.toString('base64') } });\n}\nreturn out;"
      },
      "id": "b2000000-0000-4000-8000-00000000000e",
      "name": "Encode PDF",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 520]
