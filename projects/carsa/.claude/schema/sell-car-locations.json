{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AutoDealer",
      "@id": "https://www.carsa.co.uk/sell-car/store/{slug}#localbusiness",
      "name": "Carsa {DisplayName} — Sell Your Car",
      "url": "https://www.carsa.co.uk/sell-car/store/{slug}",
      "telephone": "{linked-store:phone}",
      "email": "{linked-store:email}",
      "image": "{main-image}",
      "description": "{seo-metadescription}",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{linked-store:address}",
        "addressLocality": "{linked-store:city}",
        "addressRegion": "{region:name}",
        "postalCode": "{linked-store:postcode}",
        "addressCountry": "GB"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "{linked-store:latitude}",
        "longitude": "{linked-store:longitude}"
      },
      "makesOffer": {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Car Valuation & Purchase",
          "description": "Get an instant online valuation and sell your car or part exchange at Carsa. Same-day payment, no obligation."
        }
      },
      "parentOrganization": { "@id": "https://www.carsa.co.uk/#organization" },
      "currenciesAccepted": "GBP",
      "paymentAccepted": "Cash, Bank Transfer"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.carsa.co.uk/sell-car/store/{slug}#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.carsa.co.uk/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Sell Car",
          "item": "https://www.carsa.co.uk/sell-car"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "{DisplayName}"
        }
      ]
    }
  ]
}
