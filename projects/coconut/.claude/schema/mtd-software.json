      "mainEntityOfPage": { "@id": "https://www.getcoconut.com/mtd-software#webpage" },
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does Coconut cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Coconut's Bookkeeping plan is £99.99/year or £16.99/month. If you need to send MTD updates to HMRC, the MTD filing plan is £129.99/year or £21.99/month. You can try Coconut free for 14 days, with no card details needed, and choose the plan that fits what you need - whether that's simple bookkeeping or MTD filing."
          }
        },
        {
          "@type": "Question",
          "name": "Is Coconut on the HMRC-approved list?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Coconut is HMRC-recognised software for Making Tax Digital for Income Tax. You can check the official GOV.UK list here: Find software that works with Making Tax Digital for Income Tax"
          }
        },
        {
          "@type": "Question",
          "name": "Can I use Coconut alongside my accountant?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Coconut keeps your records organised, so it's easier to share what your accountant needs. No more digging through spreadsheets or sending over bits and pieces at the last minute!"
          }
        },
        {
          "@type": "Question",
          "name": "Can I switch from another MTD provider?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. If Coconut feels like a better fit, you can switch over. Connect your bank account, get your records up to date and manage your income, expenses and MTD updates in one place."
          }
        },
        {
          "@type": "Question",
          "name": "Does Coconut work for landlords with multiple properties?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, Coconut is built for landlords as well as sole traders. You can use it to track property income, record expenses and keep the digital records you'll need for MTD."
          }
        },
        {
          "@type": "Question",
          "name": "Is there a free trial?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can try Coconut free for 14 days, without even needing to enter any card details to get started. Find out more about our pricing. You may also be able to get Coconut free for 2 years when you open and connect a new Zempler Bank business account through Coconut, subject to eligibility and terms. Learn how to take advantage of our offer with Zempler."
          }
        }
      ]
